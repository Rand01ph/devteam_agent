# DevTeam Agent 环境变量配置

# GitLab 配置
GITLAB_URL=https://gitlab.your-company.com
GITLAB_TOKEN=your_gitlab_personal_access_token
# 可选：指定要跟踪的项目ID，逗号分隔。留空则跟踪所有可访问的项目
GITLAB_PROJECT_IDS=

# Jira 配置
JIRA_URL=https://jira.your-company.com
JIRA_USERNAME=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
# 可选：指定要跟踪的项目Key，逗号分隔。留空则跟踪所有可访问的项目
JIRA_PROJECT_KEYS=

# 团队成员配置
# 逗号分隔的团队成员账号名
TEAM_MEMBERS=zhangsan,lisi,wangwu
# 可选：显示名到账号名的映射，格式：显示名:account，多个成员使用分号分隔
# 如果你在 _pending.md 里直接使用账号名作为标题（如 ## zhangsan），可以留空
TEAM_MEMBER_NAME_MAP=

# 报告存储目录（可选，默认为 data/reports）
REPORTS_DIR=data/reports

# Claude API 配置
# ANTHROPIC_AUTH_TOKEN=your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可选，使用兼容的 API 端点
# ANTHROPIC_MODEL=claude-sonnet-4-6  # 可选，指定模型
